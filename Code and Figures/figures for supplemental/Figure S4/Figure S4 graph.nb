         "}"}]}], ",", 
       RowBox[{"ImageSize", "->", 
        RowBox[{"{", 
         RowBox[{"230", ",", "200"}], "}"}]}], ",", 
       RowBox[{"AspectRatio", "->", "Full"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Select", " ", "data", " ", "with", " ", "T"}], ">=", 
     RowBox[{"0.6", " ", "and", " ", "drop", " ", "uncertainties"}]}], "*)"}],
    "\n", 
   RowBox[{
    RowBox[{"fitData", "=", 
     RowBox[{
      RowBox[{"Select", "[", 
       RowBox[{"data3ms", ",", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ">=", "0.6"}], "&"}]}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "2"}], "}"}]}], "]"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Fit", " ", "y"}], "=", 
     RowBox[{"A", " ", 
      RowBox[{"T", "^", 
       RowBox[{"-", "1"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fit", "=", 
     RowBox[{"FindFit", "[", 
      RowBox[{"fitData", ",", 
       RowBox[{"A", " ", 
        RowBox[{"x", "^", 
         RowBox[{"-", "1"}]}]}], ",", "A", ",", "x"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Afit", "=", 
     RowBox[{"A", "/.", " ", "fit"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Fit", " ", "line", " ", "that", " ", "extrapolates", " ", "but", " ", 
     "stops", " ", "at", " ", "plot", " ", "edge"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fitLine", "=", 
     RowBox[{"LogLogPlot", "[", 
      RowBox[{
       RowBox[{"Afit", " ", 
        RowBox[{"x", "^", 
         RowBox[{"-", "1"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0.1", ",", "2"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Red", ",", 
          RowBox[{"AbsoluteThickness", "[", "1", "]"}]}], "}"}]}], ",", 
       RowBox[{"RegionFunction", "->", 
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"x", ",", "y"}], "}"}], ",", 
          RowBox[{"10", "<=", "y", "<=", "200"}]}], "]"}]}]}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Add", " ", "horizontal", " ", "line", " ", "at", " ", "T_", 
      RowBox[{"2", "^", "Hahn"}], " ", "of", " ", "100", " ", "\[Mu]s"}], ",",
      " ", 
     RowBox[{
     "slightly", " ", "higher", " ", "than", " ", "data", " ", "point", " ", 
      "at", " ", "lowest", " ", "temperature"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"horizontalLine", "=", 
     RowBox[{"LogLogPlot", "[", 
      RowBox[{"100.", ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0.1", ",", "2"}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Red", ",", 
          RowBox[{"AbsoluteThickness", "[", "1", "]"}]}], "}"}]}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"y0", "=", "100."}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Teff", "=", 
     RowBox[{"Afit", "/", "y0"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"intersection", "=", 
     RowBox[{"{", 
      RowBox[{"Teff", ",", "y0"}], "}"}]}], ";", 
    RowBox[{"Print", "[", 
     RowBox[{
     "\"\<intersection (effective TLF temperature) for plot 3 = \>\"", ",", 
      RowBox[{"NumberForm", "[", 
       RowBox[{"Teff", ",", 
        RowBox[{"{", 
         RowBox[{"Infinity", ",", "2"}], "}"}]}], "]"}], ",", "\"\< K\>\""}], 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", "Combine", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"plot3withlines", "=", 
     RowBox[{"Show", "[", 
      RowBox[{"plot3", ",", "fitLine", ",", "horizontalLine"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"now", " ", "combine", " ", "the", " ", "three", " ", "plots"}], 
