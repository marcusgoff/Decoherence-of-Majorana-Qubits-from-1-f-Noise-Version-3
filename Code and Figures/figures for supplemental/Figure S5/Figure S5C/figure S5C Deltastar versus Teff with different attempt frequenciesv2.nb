Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"GHzToMicroeV", "=", "4.13567"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"GHzToMilliK", "=", "48.0"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"ClearAll", "[", 
   RowBox[{"myDelta", ",", "mykT", ",", "myGamma0"}], "]"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"eq", "[", 
    RowBox[{
     RowBox[{"mykT_", "?", "NumericQ"}], ",", "myDelta_", ",", 
     RowBox[{"myGamma0_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"myDelta", "/", "mykT"}]}], "-", 
          RowBox[{"Log", "[", 
           RowBox[{"myGamma0", "/", "mykT"}], "]"}]}], "==", 
         RowBox[{"mykT", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "myDelta"}], ")"}]}]}], ",", 
        RowBox[{"mykT", "<", "myGamma0"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"myDelta", "/", "mykT"}]}], "==", 
         RowBox[{"mykT", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "myDelta"}], ")"}]}]}], ",", 
        RowBox[{"mykT", ">=", "myGamma0"}]}], "}"}]}], "}"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"deltaSol", "[", 
    RowBox[{
     RowBox[{"mykT_", "?", "NumericQ"}], ",", 
     RowBox[{"myGamma0_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"myDelta", "/.", " ", 
    RowBox[{"FindRoot", "[", 
     RowBox[{
      RowBox[{"eq", "[", 
       RowBox[{"mykT", ",", "myDelta", ",", "myGamma0"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"myDelta", ",", "1"}], "}"}]}], "]"}]}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"deltaPhysical", "[", 
    RowBox[{
     RowBox[{"TmK_", "?", "NumericQ"}], ",", 
     RowBox[{"gamma0GHz_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"kTGHz", ",", "deltaGHz"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"convert", " ", "input", " ", "temperature"}], "\[RightArrow]",
        "GHz"}], "*)"}], 
     RowBox[{
      RowBox[{"kTGHz", "=", 
       RowBox[{"TmK", "/", "GHzToMilliK"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"solve", " ", "equation"}], "*)"}], 
      RowBox[{"deltaGHz", "=", 
       RowBox[{"deltaSol", "[", 
        RowBox[{"kTGHz", ",", "gamma0GHz"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"convert", " ", "output"}], "\[RightArrow]", 
        RowBox[{"micro", " ", "eV"}]}], "*)"}], 
      RowBox[{"GHzToMicroeV", "*", "deltaGHz"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"Evaluate", "@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"deltaPhysical", "[", 
        RowBox[{"T", ",", "g0"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"g0", ",", 
         RowBox[{"{", 
          RowBox[{"50", ",", "150", ",", "500", ",", "1500", ",", "1"}], 
          "}"}]}], "}"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"T", ",", "1", ",", "310"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{"temperature", " ", "in", " ", "mK"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"Axes", "->", "False"}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameStyle", "->", "Black"}], ",", 
    RowBox[{"BaseStyle", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"FontSize", "->", "14"}], ",", 
       RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}]}], "}"}]}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{
      "\"\<\!\(\*SubscriptBox[\(T\), \(eff\)]\) (mK)\>\"", ",", 
       "\"\<\!\(\*SuperscriptBox[\(\[CapitalDelta]\), \(*\)]\) (\[Mu]eV)\>\"",
        ",", "None", ",", "None"}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "310"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "60"}], "}"}]}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"FrameTicks", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "10", ",", "20", ",", "30", ",", "40", ",", "50", ",", "60"}], 
          "}"}], ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0", ",", "100", ",", "200", ",", "300"}], "}"}], ",", 
         "None"}], "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{
      "\"\<\!\(\*SubscriptBox[\(\[CapitalGamma]\), \(0\)]\) = 50 GHz\>\"", 
       ",", "\"\<150 GHz\>\"", ",", "\"\<500 GHz\>\"", ",", 
       "\"\<1500 GHz\>\""}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"GridLines", "->", 
     RowBox[{"{", 
      RowBox[{"None", ",", 
       RowBox[{"{", "23.8", "}"}]}], "}"}]}], ",", "\[IndentingNewLine]", 
    RowBox[{"GridLinesStyle", "->", 
     RowBox[{"Directive", "[", 
      RowBox[{"Thick", ",", "Gray", ",", "Dashed"}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}], "\n"}], "\n"}], "Input",
