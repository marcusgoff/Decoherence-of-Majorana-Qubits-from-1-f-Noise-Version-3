Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Unit"}]}], " ", 
     RowBox[{"conversions", "--"}]}], "-"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"GHzToMicroeV", "=", "4.13567"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"GHzToMilliK", "=", "48.0"}], ";"}], "\n", "\[IndentingNewLine]", 
   
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Clear"}]}], " ", 
      RowBox[{"symbols", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ClearAll", "[", 
    RowBox[{"myDelta", ",", "mykT", ",", "myGamma0"}], "]"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Piecewise"}]}], " ", 
      RowBox[{"equation", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"eq", "[", 
      RowBox[{
       RowBox[{"mykT_", "?", "NumericQ"}], ",", "myDelta_", ",", 
       RowBox[{"myGamma0_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"2", " ", 
             RowBox[{"myDelta", "/", "mykT"}]}], "-", 
            RowBox[{"Log", "[", 
             RowBox[{"myGamma0", "/", "mykT"}], "]"}]}], "==", 
           RowBox[{"mykT", "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "myDelta"}], ")"}]}]}], ",", 
          RowBox[{"mykT", "<", "myGamma0"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{"myDelta", "/", "mykT"}]}], "==", 
           RowBox[{"mykT", "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "myDelta"}], ")"}]}]}], ",", 
          RowBox[{"mykT", ">=", "myGamma0"}]}], "}"}]}], "}"}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Solve"}]}], " ", "for", " ", "positive", " ", 
      RowBox[{"root", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"deltaSol", "[", 
      RowBox[{
       RowBox[{"mykT_", "?", "NumericQ"}], ",", 
       RowBox[{"myGamma0_", "?", "NumericQ"}]}], "]"}], ":=", 
     RowBox[{"myDelta", "/.", " ", 
      RowBox[{"FindRoot", "[", 
       RowBox[{
        RowBox[{"eq", "[", 
         RowBox[{"mykT", ",", "myDelta", ",", "myGamma0"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"myDelta", ",", "1"}], "}"}]}], "]"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", "Convert"}]}], " ", "to", " ", "physical", " ", 
      RowBox[{"units", "--"}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"deltaPhysical", "[", 
     RowBox[{
      RowBox[{"TmK_", "?", "NumericQ"}], ",", 
      RowBox[{"gamma0GHz_", "?", "NumericQ"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"kTGHz", ",", "deltaGHz"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Convert", " ", "temperature", " ", "to", " ", "GHz"}], "*)"}], 
      RowBox[{
       RowBox[{"kTGHz", "=", 
        RowBox[{"TmK", "/", "GHzToMilliK"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Solve", " ", "equation"}], "*)"}], 
       RowBox[{"deltaGHz", "=", 
        RowBox[{"deltaSol", "[", 
         RowBox[{"kTGHz", ",", "gamma0GHz"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Convert", " ", "result", " ", "to", " ", "micro"}], "-", 
         "eV"}], "*)"}], 
       RowBox[{"GHzToMicroeV", "*", "deltaGHz"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", 
       RowBox[{"Plot", "--"}]}]}], "-"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "@", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"deltaPhysical", "[", 
         RowBox[{"T", ",", "g0"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"g0", ",", 
          RowBox[{"{", 
           RowBox[{"50", ",", "150", ",", "500", ",", "1500"}], "}"}]}], 
         "}"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"T", ",", "1", ",", "310"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{"temperature", " ", "in", " ", "mK"}], "*)"}], 
     RowBox[{"Axes", "->", "False"}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameStyle", "->", "Black"}], ",", 
     RowBox[{"BaseStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"FontSize", "->", "14"}], ",", 
        RowBox[{"FontFamily", "->", "\"\<Helvetica\>\""}]}], "}"}]}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\\!\\(\\*SubscriptBox[\\(T\\), \\(eff\\)]\\) (mK)\>\"", ",", 
        "\"\<\\!\\(\\*SuperscriptBox[\\(\[CapitalDelta]\\), \\(*\\)]\\) \
(\[Mu]eV)\>\"", ",", "None", ",", "None"}], "}"}]}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "310"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "60"}], "}"}]}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"--", 
         RowBox[{"-", "Custom"}]}], " ", 
        RowBox[{"ticks", "--"}]}], "-"}], "*)"}], 
     RowBox[{"FrameTicks", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "10", ",", "20", ",", "30", ",", "40", ",", "50", ",", "60"}], 
           "}"}], ",", "None"}], "}"}], ",", 
        RowBox[{"(*", 
         RowBox[{"y", "-", "axis"}], "*)"}], 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "100", ",", "200", ",", "300"}], "}"}], ",", 
          "None"}], "}"}]}], "    ", 
       RowBox[{"(*", 
        RowBox[{"x", "-", "axis"}], "*)"}], "}"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
        RowBox[{"--", 
         RowBox[{"-", "Horizontal"}]}], " ", "reference", " ", 
        RowBox[{"line", "--"}]}], "-"}], "*)"}], 
     RowBox[{"GridLines", "->", 
      RowBox[{"{", 
       RowBox[{"None", ",", 
        RowBox[{"{", "23.8", "}"}]}], "}"}]}], ",", 
     RowBox[{"GridLinesStyle", "->", 
      RowBox[{"Directive", "[", 
       RowBox[{"Thick", ",", "Gray", ",", "Dashed"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"--", 
        RowBox[{"-", 
         RowBox[{"Legend", "--"}]}]}], "-"}], "*)"}], 
     RowBox[{"PlotLegends", "->", 
